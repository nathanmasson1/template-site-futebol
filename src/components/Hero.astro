---
import { withInternalTrailingSlash } from '../lib/urls';

interface Props { data?: any; }

const d = Astro.props.data || {};
const badge = d.badge || 'Futebol brasileiro, todos os dias';
const title = d.title || 'O Brasil entra em campo aqui';
const subtitle = d.subtitle || 'Análises, histórias e contexto para quem vive o futebol.';
const ctaPrimary = d.ctaPrimary || { text: 'Ver análises', href: '/blog/' };
const ctaSecondary = d.ctaSecondary || { text: 'Conheça a Central', href: '/sobre/' };
const heroImage = d.image || '/images/football-stadium.jpg';
const stats = d.stats || [];
const featured = d.featured || [];
---

<section class="hero">
  <div class="hero-photo" style={`background-image:url('${heroImage}')`}></div>
  <div class="hero-overlay"></div>
  <div class="hero-lines"></div>

  <div class="container hero-inner">
    <div class="hero-main">
      <div class="hero-copy">
        <span class="hero-badge"><i></i>{badge}</span>
        <h1 class="hero-title">{title}</h1>
        <p class="hero-subtitle">{subtitle}</p>
        <div class="hero-actions">
          <a href={withInternalTrailingSlash(ctaPrimary.href)} class="btn btn-primary btn-lg">
            {ctaPrimary.text}<span aria-hidden="true">→</span>
          </a>
          <a href={withInternalTrailingSlash(ctaSecondary.href)} class="btn hero-btn-outline">
            {ctaSecondary.text}
          </a>
        </div>
      </div>

      <aside class="hero-scoreboard" aria-label="Destaques editoriais">
        <div class="scoreboard-head">
          <span>Na Central</span>
          <strong>Em destaque</strong>
        </div>
        <div class="scoreboard-list">
          {featured.map((item: any, index: number) => (
            <a href={withInternalTrailingSlash(item.href || '/blog/')} class="scoreboard-item">
              <span class="scoreboard-number">{String(index + 1).padStart(2, '0')}</span>
              <span class="scoreboard-copy">
                <small>{item.tag}</small>
                <strong>{item.title}</strong>
              </span>
              <span class="scoreboard-arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </aside>
    </div>

    <div class="hero-stats" aria-label="Pilares da Central Brasileirão">
      {stats.map((stat: any) => (
        <div class="hero-stat">
          <strong>{stat.number}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg-dark);
    color: #fff;
    min-height: 760px;
    overflow: hidden;
    padding: calc(var(--navbar-height) + var(--space-4xl)) 0 var(--space-3xl);
    position: relative;
  }

  .hero-photo,
  .hero-overlay,
  .hero-lines { inset: 0; position: absolute; }

  .hero-photo {
    background-position: center;
    background-size: cover;
    filter: saturate(0.88) contrast(1.08);
    transform: scale(1.02);
  }

  .hero-overlay {
    background:
      linear-gradient(90deg, rgba(4, 21, 15, 0.98) 0%, rgba(4, 21, 15, 0.88) 44%, rgba(4, 21, 15, 0.45) 100%),
      linear-gradient(0deg, rgba(4, 21, 15, 0.96) 0%, transparent 52%);
  }

  .hero-lines {
    background-image:
      linear-gradient(90deg, rgba(200, 255, 61, 0.05) 1px, transparent 1px),
      linear-gradient(rgba(200, 255, 61, 0.05) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(90deg, #000, transparent 75%);
  }

  .hero-inner { position: relative; z-index: 2; }

  .hero-main {
    align-items: end;
    display: grid;
    gap: clamp(2rem, 6vw, 6rem);
    grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr);
  }

  .hero-copy { max-width: 760px; }

  .hero-badge {
    align-items: center;
    color: var(--color-accent);
    display: inline-flex;
    font-size: var(--fs-xs);
    font-weight: 800;
    gap: var(--space-sm);
    letter-spacing: var(--ls-widest);
    margin-bottom: var(--space-xl);
    text-transform: uppercase;
  }

  .hero-badge i {
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 0 6px rgba(200, 255, 61, 0.12);
    height: 8px;
    width: 8px;
  }

  .hero-title {
    color: #fff;
    font-size: var(--fs-hero);
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 0.86;
    margin-bottom: var(--space-xl);
    max-width: 9ch;
    text-transform: uppercase;
  }

  .hero-title::first-line { color: #fff; }

  .hero-subtitle {
    border-left: 4px solid var(--color-accent);
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 2vw, 1.22rem);
    line-height: 1.65;
    margin-bottom: var(--space-2xl);
    max-width: 610px;
    padding-left: var(--space-lg);
  }

  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-md); }
  .btn-lg { min-height: 52px; padding: 1rem 1.55rem; }

  .hero-btn-outline {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  .hero-btn-outline:hover { background: #fff; color: var(--color-accent-dark); }

  .hero-scoreboard {
    backdrop-filter: blur(12px);
    background: rgba(4, 21, 15, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-top: 5px solid var(--color-accent);
    box-shadow: var(--shadow-xl);
  }

  .scoreboard-head {
    align-items: end;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    justify-content: space-between;
    padding: var(--space-lg);
  }

  .scoreboard-head span {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
  }

  .scoreboard-head strong {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 1.35rem;
    text-transform: uppercase;
  }

  .scoreboard-item {
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    display: grid;
    gap: var(--space-md);
    grid-template-columns: auto 1fr auto;
    padding: var(--space-lg);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .scoreboard-item:last-child { border-bottom: 0; }
  .scoreboard-item:hover { background: var(--color-accent); color: var(--color-accent-dark); }

  .scoreboard-number {
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 1.7rem;
    font-weight: 900;
  }

  .scoreboard-item:hover .scoreboard-number,
  .scoreboard-item:hover small { color: var(--color-accent-dark); }

  .scoreboard-copy { display: block; }
  .scoreboard-copy small {
    color: var(--color-primary-light);
    display: block;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: var(--ls-wider);
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .scoreboard-copy strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    line-height: 1.08;
    text-transform: uppercase;
  }

  .scoreboard-arrow { font-size: 1.2rem; }

  .hero-stats {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    display: grid;
    gap: 0;
    grid-template-columns: repeat(3, 1fr);
    margin-top: var(--space-3xl);
  }

  .hero-stat {
    align-items: center;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl) 0 0;
  }

  .hero-stat:last-child { border-right: 0; padding-left: var(--space-xl); }
  .hero-stat:nth-child(2) { padding-left: var(--space-xl); }

  .hero-stat strong {
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .hero-stat span {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: var(--ls-wide);
    line-height: 1.35;
    max-width: 150px;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .hero { min-height: auto; }
    .hero-main { align-items: stretch; grid-template-columns: 1fr; }
    .hero-copy { max-width: 820px; }
    .hero-title { max-width: 11ch; }
  }

  @media (max-width: 700px) {
    .hero { padding-bottom: var(--space-2xl); }
    .hero-title { font-size: clamp(3.5rem, 17vw, 5rem); }
    .hero-stats { grid-template-columns: 1fr; }
    .hero-stat,
    .hero-stat:nth-child(2),
    .hero-stat:last-child {
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      border-right: 0;
      padding: var(--space-md) 0;
    }
    .hero-stat:last-child { border-bottom: 0; }
    .scoreboard-item { padding: var(--space-md); }
  }
</style>
