---
import { getCollection } from 'astro:content';
import PostCard from './PostCard.astro';
import { isPostPublic } from '../lib/postVisibility';
import categoriesRaw from '../data/categories.json';
import { withInternalTrailingSlash } from '../lib/urls';

interface Props {
  data?: any;
  limit?: number;
}

const d = Astro.props.data || {};
const limit = d.limit || Astro.props.limit || 6;
const label = d.label || 'Central do jogo';
const title = d.title || 'Futebol para entender e debater';
const subtitle = d.subtitle || 'Análises e histórias sobre o futebol brasileiro.';
const ctaText = d.ctaText || 'Ver todos os conteúdos';
const ctaHref = withInternalTrailingSlash(d.ctaHref || '/blog/');
const allowedCategories = new Set((categoriesRaw as Array<{ slug: string }>).map((category) => category.slug));

const posts = (await getCollection('blog', ({ data }) => isPostPublic(data)))
  .filter((post) => allowedCategories.has(post.data.category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, limit);
---

<section class="posts-section section" id="posts">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">{label}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <div class="posts-grid stagger-children animate-on-scroll">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          image={post.data.image}
          imageAlt={post.data.imageAlt}
          category={post.data.category}
          slug={post.id}
          rating={post.data.rating}
          badge={post.data.badge}
          priceRange={post.data.priceRange}
        />
      ))}
    </div>

    <div class="posts-cta animate-on-scroll">
      <div class="divider">
        <div class="divider-icon"></div>
      </div>
      <a href={ctaHref} class="btn btn-outline">
        {ctaText}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .posts-section {
    background: var(--color-bg);
  }

  .posts-section :global(.section-header) {
    padding-bottom: var(--space-xl);
    border-bottom: 4px solid var(--color-accent);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .posts-cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
