---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  variant?: 'desktop' | 'mobile' | 'both';
}

const { headings, variant = 'both' } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showDesktop = variant === 'desktop' || variant === 'both';
const showMobile = variant === 'mobile' || variant === 'both';
---

{filteredHeadings.length > 0 && (
  <>
    {/* Desktop TOC */}
    {showDesktop && <nav class="toc toc-desktop" aria-label="Sumário do artigo">
      <p class="toc-title">Neste artigo</p>
      <ul class="toc-list">
        {filteredHeadings.map((heading) => (
          <li class:list={['toc-item', { 'toc-item-sub': heading.depth === 3 }]}>
            <a href={`#${heading.slug}`} class="toc-link" data-heading={heading.slug}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>}

    {/* Mobile TOC */}
    {showMobile && <details class="toc toc-mobile">
      <summary class="toc-mobile-toggle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Sumário do artigo
      </summary>
      <ul class="toc-list">
        {filteredHeadings.map((heading) => (
          <li class:list={['toc-item', { 'toc-item-sub': heading.depth === 3 }]}>
            <a href={`#${heading.slug}`} class="toc-link">
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </details>}
  </>
)}

<style>
  .toc {
    font-size: var(--fs-sm);
  }

  /* Desktop */
  .toc-desktop {
    display: none;
  }

  @media (min-width: 1280px) {
    .toc-desktop {
      display: block;
      position: sticky;
      top: calc(var(--navbar-height) + var(--space-xl));
      max-height: calc(100vh - var(--navbar-height) - var(--space-3xl));
      overflow-y: auto;
    }
  }

  .toc-title {
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: var(--color-text-faint);
    margin-bottom: var(--space-md);
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--color-border-light);
  }

  .toc-item {
    list-style: none;
  }

  .toc-link {
    display: block;
    padding: 0.35rem 0 0.35rem var(--space-lg);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    font-weight: var(--fw-regular);
    line-height: var(--lh-normal);
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .toc-link:hover {
    color: var(--color-primary);
    border-left-color: var(--color-primary-lighter);
  }

  .toc-link.active {
    color: var(--color-primary);
    font-weight: var(--fw-semibold);
    border-left-color: var(--color-primary);
  }

  .toc-item-sub .toc-link {
    padding-left: calc(var(--space-lg) + var(--space-md));
    font-size: 0.7rem;
  }

  /* Mobile */
  .toc-mobile {
    display: block;
    margin-bottom: var(--space-xl);
    background: var(--color-bg-cool);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    overflow: hidden;
  }

  @media (min-width: 1280px) {
    .toc-mobile {
      display: none;
    }
  }

  .toc-mobile-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-text-secondary);
    cursor: pointer;
    list-style: none;
  }

  .toc-mobile-toggle::-webkit-details-marker {
    display: none;
  }

  .toc-mobile .toc-list {
    padding: 0 var(--space-lg) var(--space-lg);
    border-left: none;
    margin-left: var(--space-lg);
    border-left: 1px solid var(--color-border-light);
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc-desktop .toc-link');
  const headings = Array.from(tocLinks).map((link) => {
    const id = link.getAttribute('data-heading');
    return id ? document.getElementById(id) : null;
  }).filter(Boolean) as HTMLElement[];

  if (headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-desktop .toc-link[data-heading="${entry.target.id}"]`);
            activeLink?.classList.add('active');
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px' }
    );
    headings.forEach((heading) => observer.observe(heading));
  }
</script>
